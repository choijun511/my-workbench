{
  "manifest_version": 3,
  "name": "My Workbench Capture",
  "version": "1.1.0",
  "description": "Capture screenshots and AI-chat decisions into my-workbench (auto Insight + structured decision records).",
  "permissions": ["tabs", "debugger", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "My Workbench: 捕获选中文本为决策"
  },
  "commands": {
    "capture-decision": {
      "suggested_key": {
        "default": "Alt+Shift+D",
        "mac": "Alt+Shift+D"
      },
      "description": "捕获选中文本为决策"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://my-workbench.onrender.com/*",
        "http://localhost:5173/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
